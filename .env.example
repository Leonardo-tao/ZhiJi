# 生成随机密钥: https://generate-secret.vercel.app/32 或者 `openssl rand -base64 32`
AUTH_SECRET=****

# 在 https://vercel.com/ai-gateway 创建 AI Gateway API 密钥
# 非 Vercel 部署需要 API 密钥
# Vercel 部署自动使用 OIDC 令牌
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# 在 https://vercel.com/docs/vercel-blob 创建 Vercel Blob 存储
BLOB_READ_WRITE_TOKEN=****

# 在 https://vercel.com/docs/postgres 创建 PostgreSQL 数据库
POSTGRES_URL=****


# 在 https://vercel.com/docs/redis 创建 Redis 存储
REDIS_URL=****

# 在 https://platform.deepseek.com/api_keys 创建 Deepseek API 密钥
DEEPSEEK_API_KEY=****
